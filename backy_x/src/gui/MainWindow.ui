  <action name="actionToggleFileViewer"><property name="text"><string>Remote File Browser</string></property></action>
  <action name="actionRunBackup"><property name="text"><string>Run Backup Now</string></property><property name="shortcut"><string>Ctrl+R</string></property></action>
