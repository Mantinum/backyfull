        </layout>
       </widget>

       <widget class="QWidget" name="pageLogs">
        <layout class="QVBoxLayout" name="vlLogs">
         <item><widget class="QPlainTextEdit" name="teLogs"><property name="readOnly"><bool>true</bool></property></widget></item>
         <item><widget class="QPushButton" name="btnClearLogs"><property name="text"><string>Clear</string></property></widget></item>
        </layout>
